{
  "name": "invest-codex",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "stop": "kill-port 7100 7001 7000 3000 5173",
    "dev:reset": "npm run dev",
    "dev": "npm run stop && concurrently -k -n api,web -c blue,green \"npm run dev:api\" \"npm run dev:web\"",
    "dev:ca": "node scripts/dev-ca.cjs",
    "dev:insecure": "cross-env NODE_TLS_REJECT_UNAUTHORIZED=0 npm run dev",
    "dev:api": "npm run dev -w @invest/api",
    "dev:web": "npm run dev -w @invest/web",
    "build": "npm run build -w @invest/api && npm run build -w @invest/web",
    "typecheck": "npm run typecheck -w @invest/api && npm run typecheck -w @invest/web"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "kill-port": "^2.0.1",
    "cross-env": "^7.0.3"
  },
  "packageManager": "pnpm@10.30.3+sha512.c961d1e0a2d8e354ecaa5166b822516668b7f44cb5bd95122d590dd81922f606f5473b6d23ec4a5be05e7fcd18e8488d47d978bbe981872f1145d06e9a740017"
}
